#include <stdio.h>

int ehValido(char c)
{
    return c == 'X' || c == 'O';
}

void salvarTabuleiro(char matriz[3][3], char nomeArquivo[])
{
    FILE *arq;

    arq = fopen(nomeArquivo, "w");

    if(arq == NULL)
    {
        printf("Erro ao abrir o arquivo.\n");
        return;
    }

    for(int i = 0; i < 3; i++)
    {
        fprintf(arq,
                "| %c | %c | %c |\n",
                matriz[i][0],
                matriz[i][1],
                matriz[i][2]);
    }

    fprintf(arq, "\n");
    fprintf(arq, "Criado por Miguel de Mello Gomes");

    fclose(arq);
}
